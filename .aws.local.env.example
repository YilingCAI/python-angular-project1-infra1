# Local-only AWS credentials for bootstrap and Makefile commands.
# Copy to .aws.local.env and fill with real values.

AWS_REGION=us-east-1
AWS_DEFAULT_REGION=us-east-1
AWS_ACCOUNT_ID=123456789012
AWS_ACCESS_KEY_ID=REPLACE_ME
AWS_SECRET_ACCESS_KEY=REPLACE_ME
# AWS_SESSION_TOKEN=REPLACE_ME_IF_USING_TEMP_CREDS
