#!/usr/bin/env bash
set -euo pipefail

# Block committing local credential file.
if git diff --cached --name-only | grep -qx '.aws.local.env'; then
  echo 'ERROR: .aws.local.env is staged. Remove it from commit:' >&2
  echo '  git restore --staged .aws.local.env' >&2
  exit 1
fi

# Block common AWS key patterns in staged diff.
staged_patch="$(git diff --cached)"
if echo "$staged_patch" | grep -E 'AKIA[0-9A-Z]{16}|ASIA[0-9A-Z]{16}' >/dev/null; then
  echo 'ERROR: Possible AWS Access Key ID detected in staged changes.' >&2
  exit 1
fi

if echo "$staged_patch" | grep -E 'AWS_SECRET_ACCESS_KEY\s*=\s*[A-Za-z0-9/+=]{30,}' >/dev/null; then
  echo 'ERROR: Possible AWS Secret Access Key detected in staged changes.' >&2
  exit 1
fi
